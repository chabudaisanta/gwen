{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "build_without_naming",
            "command": "/usr/bin/g++",
            "args": [
                "-fdiagnostics-color=always",
                "-Wall",
                "-Wextra",
                "-std=gnu++23",
                "-g",
                "${file}",
                "-o",
                "${workspaceFolder}/debug/a.exe",
                "-I",
                "/home/chabudaisanta/lib/ac-library-master",
                "-I",
                "${workspaceFolder}",
                "-I",
                "/home/chabudaisanta/lib/gwen/include/",
                "-I",
                "/usr/include/eigen3/",
                "-I",
                "/home/chabudaisanta/lib/gwen/references/",
                "-DLOCAL",
                "-O2",
                "-mtune=native",
                "-march=native",
                "-lgmpxx",
                "-lgmp",
                "-fsanitize=undefined",
                "-fconstexpr-depth=1024",
                "-fconstexpr-loop-limit=524288",
                "-fconstexpr-ops-limit=2097152",
                "-flto=auto",
                "-fmodules",
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ],
    "version": "2.0.0"
}